{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase DOCUMENTATION - 文档生成",
  "version": "1.0.0",
  "description": "全文档归档（README / ARCHITECTURE / API / DEPLOYMENT / USER_GUIDE）",

  "phase": "DOCUMENTATION",
  "order": 8,
  "loop_agent_version": "v1.0",

  "entry_conditions": ["KNOWLEDGE.completed"],

  "tasks": [
    {
      "id": "T8-1",
      "agent": "documenter",
      "action": "consolidate_readme",
      "input": ["blackboard/requirements/baseline-v1.0.json", "blackboard/code/backend/src/", "blackboard/code/frontend/src/"],
      "output": "docs/README.md",
      "dependencies": []
    },
    {
      "id": "T8-2",
      "agent": "documenter",
      "action": "consolidate_architecture",
      "input": ["blackboard/architecture/"],
      "output": "docs/ARCHITECTURE.md",
      "dependencies": []
    },
    {
      "id": "T8-3",
      "agent": "documenter",
      "action": "consolidate_api",
      "input": ["blackboard/architecture/openapi.yaml", "blackboard/code/backend/src/"],
      "output": "docs/API.md",
      "dependencies": []
    },
    {
      "id": "T8-4",
      "agent": "documenter",
      "action": "consolidate_deployment",
      "input": ["blackboard/architecture/tech-stack.md", "blackboard/architecture/modules.md"],
      "output": "docs/DEPLOYMENT.md",
      "dependencies": []
    },
    {
      "id": "T8-5",
      "agent": "documenter",
      "action": "consolidate_user_guide",
      "input": ["blackboard/ux/journey-map.md", "blackboard/ui/components.md"],
      "output": "docs/USER_GUIDE.md",
      "dependencies": []
    },
    {
      "id": "T8-6",
      "agent": "documenter",
      "action": "consolidate_reports",
      "input": ["blackboard/performance/perf-report.json", "blackboard/test_reports/test-report.json", "blackboard/knowledge/lessons.md"],
      "output": "docs/REPORTS.md",
      "dependencies": []
    }
  ],

  "exit_gate": "all_docs_complete_and_validated",

  "budget": { "cost_usd": 5, "iterations": 10 },

  "prev_phase": "KNOWLEDGE",
  "next_phase": "FINAL_REVIEW"
}
