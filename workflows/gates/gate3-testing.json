{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gate 3 - 全栈测试门禁",
  "version": "1.0.0",
  "description": "由 @全栈测试员 执行 5 大维度测试",

  "gate_id": "GATE_3",
  "gate_name": "全栈测试门禁",
  "loop_agent_version": "v1.0",

  "agent": "tester",
  "skill": "gate3-testing",
  "permission": "read_only",

  "trigger": "GATE_2.passed",
  "embedded_in_phase": "QUALITY_GATES",

  "input_paths": [
    "blackboard/code/backend/src/",
    "blackboard/code/frontend/src/",
    "blackboard/architecture/openapi.yaml",
    "blackboard/requirements/baseline-v1.0.json"
  ],
  "output_path": "blackboard/test_reports/test-report-<taskId>.json",

  "test_dimensions": [
    "functional",
    "api",
    "security",
    "usability",
    "compatibility"
  ],

  "bug_thresholds": {
    "p0_bugs_max": 0,
    "p1_bugs_max": 0,
    "p2_bugs_max": 3,
    "p3_bugs_max": 999
  },

  "coverage_requirements": {
    "core_business_coverage_min": 100,
    "api_coverage_min": 100
  },

  "pass_criteria": "p0 == 0 AND p1 == 0 AND p2 <= 3 AND core_business_coverage == 100 AND api_coverage == 100",

  "fail_action": "→ bug_defect_repairer → 回到 DEVELOPMENT",

  "max_attempts": 3,
  "timeout_seconds": 3600
}
