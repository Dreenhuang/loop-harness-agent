{
  "name": "loop-agent",
  "version": "1.2.0",
  "description": "Loop-Harness-Agent × Boss-auto-harness 融合模式 · 16 角色 × 10 相位 × 4 道门禁",
  "type": "module",
  "bin": {
    "loop-agent": "./bin/loop-agent.js"
  },
  "scripts": {
    "init": "node bin/loop-agent.js init",
    "loop": "node bin/loop-agent.js loop",
    "status": "node bin/loop-agent.js status",
    "abort": "node bin/loop-agent.js abort",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}'"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.57.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
