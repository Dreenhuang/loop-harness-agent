{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRD→生产 全链路自动化开发 Workflow Blueprint",
  "version": "1.1.0",
  "description": "Loop Agent 系统的 10 相位完整工作流蓝图。基于 Agent Loop Engineering + Harness Engineering + 16 大角色 AGENT TEAM。v1.1 融合 Boss-auto-harness 验收标准与执行纪律。",
  "loop_agent_version": "v1.1",
  "fusion_standard": "g:\\ai-gongju\\Loop-agent\\docs\\integration\\融合验收标准.md",
  "trae_solo_alignment": "v1.1",

  "phase_references": {
    "INIT": "../../workflows/phases/01-INIT.json",
    "REQUIREMENTS": "../../workflows/phases/02-REQUIREMENTS.json",
    "DESIGN": "../../workflows/phases/03-DESIGN.json",
    "ARCHITECTURE": "../../workflows/phases/04-ARCHITECTURE.json",
    "DEVELOPMENT": "../../workflows/phases/05-DEVELOPMENT.json",
    "QUALITY_GATES": "../../workflows/phases/06-QUALITY_GATES.json",
    "KNOWLEDGE": "../../workflows/phases/07-KNOWLEDGE.json",
    "DOCUMENTATION": "../../workflows/phases/08-DOCUMENTATION.json",
    "FINAL_REVIEW": "../../workflows/phases/09-FINAL_REVIEW.json",
    "DEPLOY": "../../workflows/phases/10-DEPLOY.json"
  },

  "gate_references": {
    "GATE_1_code_review": "../../workflows/gates/gate1-code-review.json",
    "GATE_2_performance": "../../workflows/gates/gate2-performance.json",
    "GATE_3_testing": "../../workflows/gates/gate3-testing.json",
    "GATE_4_final": "../../workflows/gates/gate4-final.json"
  },

  "state_machine_implementation": {
    "type": "TypeScript + Bun",
    "entry": "loop-agent-engine/orchestrator.ts",
    "cli": "loop-agent-engine/cli.ts",
    "runtime": "bun run loop-agent-engine/cli.ts"
  },

  "global": {
    "project_name": "auto-dev-pipeline",
    "max_budget_usd": 100.0,
    "max_iterations": 200,
    "max_attempts_per_task": 3,
    "parallelism": 16,
    "ralph_mode": true,
    "loud_failure_only": true,
    "blackboard_required": true,
    "worktree_base": "./worktrees",
    "fusion_targets": {
      "full_auto_closed_loop": true,
      "production_grade_delivery": true,
      "direct_deploy_ready": true,
      "token_efficiency": true,
      "flow_convergence": true
    },
    "mandatory_artifacts": [
      "Product-Spec.md",
      "Design-Brief.md",
      "UI-Design.md",
      "Component-Library.md",
      "DEV-PLAN.md",
      "Quality-Check-Report.md",
      "Test-Report.md",
      "Code-Review-Report.md",
      "UX-Review-Report.md",
      "Release-Notes.md"
    ],
    "mandatory_evidence": [
      "failing_test",
      "passing_test",
      "verification_commands",
      "review_feedback",
      "deploy_smoke_test"
    ]
  },

  "phases": [
    {
      "id": "PHASE_0",
      "name": "初始化",
      "description": "建黑板 + 加载 4 级封装资产 + 验证环境",
      "agents": ["@Orchestrator"],
      "parallel": false,
      "entry_conditions": ["loop_agent_triggered"],
      "tasks": [
        {
          "id": "T0-1",
          "agent": "@Orchestrator",
          "action": "load_blackboard",
          "input": "项目进度记录.md",
          "output": "进度总结"
        },
        {
          "id": "T0-2",
          "agent": "@Orchestrator",
          "action": "load_skills",
          "input": ".trae/skills/",
          "output": "skills_loaded"
        },
        {
          "id": "T0-3",
          "agent": "@Orchestrator",
          "action": "load_agents",
          "input": ".trae/agents/",
          "output": "agents_loaded"
        },
        {
          "id": "T0-4",
          "agent": "@Orchestrator",
          "action": "load_workflow",
          "input": "prd-to-production.json",
          "output": "workflow_loaded"
        },
        {
          "id": "T0-5",
          "agent": "@Orchestrator",
          "action": "create_snapshot",
          "input": "CP-000",
          "output": ".blackboard/snapshots/CP-000.json"
        }
      ],
      "exit_gate": "all_assets_loaded",
      "budget": { "cost_usd": 1, "iterations": 2 }
    },

    {
      "id": "PHASE_1",
      "name": "需求基线",
      "description": "PM 决策 + 需求细化 + 基线冻结",
      "agents": ["@Product-Manager", "@Requirements"],
      "parallel": false,
      "entry_conditions": ["PHASE_0.completed"],
      "tasks": [
        {
          "id": "T1-1",
          "agent": "@Product-Manager",
          "action": "product_planning",
          "input": "原始 PRD",
          "output": "产品决策",
          "depends_on": []
        },
        {
          "id": "T1-2",
          "agent": "@Requirements",
          "action": "prd_creation",
          "input": "@Product-Manager 决策",
          "output": "docs/prd.md",
          "depends_on": ["T1-1"]
        },
        {
          "id": "T1-3",
          "agent": "@Requirements",
          "action": "acceptance_matrix",
          "input": "docs/prd.md",
          "output": "docs/acceptance-matrix.md",
          "depends_on": ["T1-2"]
        },
        {
          "id": "T1-4",
          "agent": "@Requirements",
          "action": "baseline_freeze",
          "input": "PRD + 验收矩阵",
          "output": "baseline_v1.0",
          "depends_on": ["T1-3"]
        }
      ],
      "exit_gate": "requirements_baseline_frozen",
      "harness_discipline": {
        "mandatory_skill": "brainstorming",
        "enforcement": "苏格拉底式需求澄清，一次一问，必须探索 2-3 个替代方案",
        "artifact_check": ["Product-Spec.md"],
        "evidence_check": ["需求澄清问答记录"]
      },
      "budget": { "cost_usd": 5, "iterations": 10 }
    },

    {
      "id": "PHASE_2",
      "name": "交互设计",
      "description": "UX 流程 + 用户旅程 + 原型",
      "agents": ["@UX-Researcher"],
      "parallel": false,
      "entry_conditions": ["PHASE_1.completed"],
      "tasks": [
        {
          "id": "T2-1",
          "agent": "@UX-Researcher",
          "action": "ux_flow_design",
          "input": "PRD",
          "output": "docs/ux/flow-diagram.md",
          "depends_on": []
        },
        {
          "id": "T2-2",
          "agent": "@UX-Researcher",
          "action": "user_journey_map",
          "input": "PRD",
          "output": "docs/ux/journey-map.md",
          "depends_on": []
        },
        {
          "id": "T2-3",
          "agent": "@UX-Researcher",
          "action": "wireframe_prototype",
          "input": "PRD + Flow",
          "output": "docs/ux/wireframe.fig",
          "depends_on": ["T2-1"]
        }
      ],
      "exit_gate": "ux_scenario_coverage_100",
      "harness_discipline": {
        "mandatory_skill": "web-design-guidelines",
        "enforcement": "设计方向必须经过 web-design-guidelines 审查",
        "artifact_check": ["Design-Brief.md"],
        "evidence_check": ["设计方向审查记录"]
      },
      "budget": { "cost_usd": 5, "iterations": 10 }
    },

    {
      "id": "PHASE_3",
      "name": "视觉设计",
      "description": "UI 设计 + 组件规范 + Design Token",
      "agents": ["@UI-Designer"],
      "parallel": false,
      "entry_conditions": ["PHASE_2.completed"],
      "tasks": [
        {
          "id": "T3-1",
          "agent": "@UI-Designer",
          "action": "design_system_apply",
          "input": "设计 Token + 组件库",
          "output": "docs/ui/design-system.md",
          "depends_on": []
        },
        {
          "id": "T3-2",
          "agent": "@UI-Designer",
          "action": "high_fidelity_design",
          "input": "Wireframe + Design System",
          "output": "docs/ui/design.fig",
          "depends_on": ["T2-3", "T3-1"]
        },
        {
          "id": "T3-3",
          "agent": "@UI-Designer",
          "action": "component_spec",
          "input": "Design + PRD",
          "output": "docs/ui/components.md",
          "depends_on": ["T3-2"]
        }
      ],
      "exit_gate": "taste_skill_validated",
      "harness_discipline": {
        "mandatory_skills": ["ui-designer", "frontend-design", "interaction-design", "web-design-guidelines", "impeccable"],
        "enforcement": "必须调用 6 个专业 UI 设计 Skill，缺一不可；严禁 AI 自行定义具体样式",
        "artifact_check": ["UI-Design.md", "Component-Library.md"],
        "evidence_check": ["6 Skill 调用记录", "反模式审计结果"]
      },
      "budget": { "cost_usd": 5, "iterations": 10 }
    },

    {
      "id": "PHASE_4",
      "name": "技术架构",
      "description": "架构设计 + 技术选型 + API 规范",
      "agents": ["@Architect"],
      "parallel": false,
      "entry_conditions": ["PHASE_1.completed"],
      "tasks": [
        {
          "id": "T4-1",
          "agent": "@Architect",
          "action": "tech_stack_selection",
          "input": "PRD + 非功能需求",
          "output": "docs/architecture/tech-stack.md",
          "depends_on": []
        },
        {
          "id": "T4-2",
          "agent": "@Architect",
          "action": "module_design",
          "input": "PRD + Tech Stack",
          "output": "docs/architecture/modules.md",
          "depends_on": ["T4-1"]
        },
        {
          "id": "T4-3",
          "agent": "@Architect",
          "action": "api_spec",
          "input": "PRD + Modules",
          "output": "docs/api/openapi.yaml",
          "depends_on": ["T4-2"]
        },
        {
          "id": "T4-4",
          "agent": "@Architect",
          "action": "data_flow_design",
          "input": "Modules + API",
          "output": "docs/architecture/data-flow.md",
          "depends_on": ["T4-3"]
        },
        {
          "id": "T4-5",
          "agent": "@Architect",
          "action": "risk_assessment",
          "input": "全部",
          "output": "docs/architecture/risks.md",
          "depends_on": ["T4-4"]
        }
      ],
      "exit_gate": "architecture_implementable",
      "harness_discipline": {
        "enforcement": "架构设计必须产出可执行的技术方案，不接受概念级架构",
        "artifact_check": ["Architecture.md", "API-Spec.md"],
        "evidence_check": ["技术选型对比记录", "风险评估记录"]
      },
      "budget": { "cost_usd": 10, "iterations": 15 }
    },

    {
      "id": "PHASE_5",
      "name": "并行开发",
      "description": "前后端并行开发（fan-out）",
      "agents": ["@Backend", "@Fullstack-Coder"],
      "parallel": true,
      "entry_conditions": ["PHASE_4.completed"],
      "tasks": [
        {
          "id": "T5-BE",
          "agent": "@Backend",
          "action": "backend_development",
          "input": "架构 + API 规范",
          "output": "src/backend/",
          "depends_on": [],
          "internal_loop": "code → test → gate1 → fix → repeat"
        },
        {
          "id": "T5-FE",
          "agent": "@Fullstack-Coder",
          "action": "frontend_development",
          "input": "设计稿 + 架构 + API",
          "output": "src/frontend/",
          "depends_on": [],
          "internal_loop": "code → test → gate1 → fix → repeat"
        }
      ],
      "exit_gate": "all_code_compiled_and_tested",
      "harness_discipline": {
        "mandatory_skills": ["writing-plans", "test-driven-development", "subagent-driven-development", "using-git-worktrees"],
        "enforcement": "必须先形成微任务级 DEV-PLAN.md；关键新功能必须 TDD RED-GREEN-REFACTOR 闭环；复杂任务自动启用子代理；每个 Phase 在独立 worktree 中开发",
        "artifact_check": ["DEV-PLAN.md"],
        "evidence_check": ["failing_test", "passing_test", "refactor_evidence"],
        "tdd_required": true,
        "microtask_granularity": "2-5 分钟",
        "subagent_auto_trigger": { "min_tasks": 5, "min_duration_minutes": 30 }
      },
      "budget": { "cost_usd": 40, "iterations": 80 }
    },

    {
      "id": "PHASE_6",
      "name": "多层质量门禁",
      "description": "4 道门禁严格把关（gate1 → gate2 → gate3 → gate4 在 phase 9）",
      "agents": ["@Code-Reviewer", "@Professional-Performance", "@全栈测试员", "@Bug-Defect-Repairer"],
      "parallel": false,
      "entry_conditions": ["PHASE_5.completed"],
      "sub_phases": [
        {
          "id": "GATE_1",
          "name": "代码质量门禁",
          "agent": "@Code-Reviewer",
          "skill": "gate1-code-review",
          "failure_path": "→ @Bug-Defect-Repairer → 回到 PHASE_5"
        },
        {
          "id": "GATE_2",
          "name": "性能门禁",
          "agent": "@Professional-Performance",
          "skill": "gate2-performance",
          "failure_path": "→ @Bug-Defect-Repairer → 回到 PHASE_5"
        },
        {
          "id": "GATE_3",
          "name": "全栈测试门禁",
          "agent": "@全栈测试员",
          "skill": "gate3-testing",
          "failure_path": "→ @Bug-Defect-Repairer → 回到 PHASE_5"
        }
      ],
      "exit_gate": "gate1_passed AND gate2_passed AND gate3_passed",
      "harness_discipline": {
        "mandatory_skills": ["verification-before-completion", "quality-gate", "test-driven-development", "requesting-code-review", "receiving-code-review"],
        "enforcement": "完成前验证铁律：任何完成声明前必须有当场验证证据；质量门禁 5 项检查必须全部通过；代码审查反馈必须逐项回应修复；TDD 覆盖率 > 80%",
        "artifact_check": ["Quality-Check-Report.md", "Test-Report.md", "Code-Review-Report.md"],
        "evidence_check": ["verification_commands", "review_feedback"],
        "fresh_evidence_required": true,
        "no_soft_claims": true
      },
      "budget": { "cost_usd": 25, "iterations": 50 }
    },

    {
      "id": "PHASE_7",
      "name": "知识沉淀",
      "description": "经验沉淀 + 知识库更新",
      "agents": ["@Knowledge-Curator"],
      "parallel": false,
      "entry_conditions": ["PHASE_6.completed"],
      "tasks": [
        {
          "id": "T7-1",
          "agent": "@Knowledge-Curator",
          "action": "extract_lessons",
          "input": "全流程产出 + Bug 记录",
          "output": "docs/knowledge/lessons.md",
          "depends_on": []
        },
        {
          "id": "T7-2",
          "agent": "@Knowledge-Curator",
          "action": "update_kb",
          "input": "lessons.md",
          "output": "knowledge_base_index",
          "depends_on": ["T7-1"]
        }
      ],
      "exit_gate": "all_experiences_indexed",
      "budget": { "cost_usd": 5, "iterations": 10 }
    },

    {
      "id": "PHASE_8",
      "name": "文档生成",
      "description": "全文档归档",
      "agents": ["@Documenter"],
      "parallel": false,
      "entry_conditions": ["PHASE_7.completed"],
      "tasks": [
        {
          "id": "T8-1",
          "agent": "@Documenter",
          "action": "consolidate_docs",
          "input": "全流程产出",
          "output": "docs/README.md / ARCHITECTURE.md / API.md / DEPLOYMENT.md / USER_GUIDE.md",
          "depends_on": []
        }
      ],
      "exit_gate": "all_docs_complete_and_validated",
      "budget": { "cost_usd": 5, "iterations": 10 }
    },

    {
      "id": "PHASE_9",
      "name": "最终终审",
      "description": "Gate 4 终审 + 上线决策",
      "agents": ["@Final-Reviewer"],
      "parallel": false,
      "entry_conditions": ["PHASE_8.completed"],
      "tasks": [
        {
          "id": "T9-1",
          "agent": "@Final-Reviewer",
          "action": "final_review",
          "input": "所有产出 + 所有门禁报告",
          "output": "终审报告 + 上线决策",
          "skill": "gate4-final",
          "depends_on": []
        }
      ],
      "exit_gate": "final_decision == GO OR CONDITIONAL_GO",
      "harness_discipline": {
        "mandatory_skills": ["verification-before-completion"],
        "enforcement": "终审前必须验证所有强制工件齐全、所有证据齐全、所有 Gate 已通过、部署前提完备",
        "artifact_check": ["ALL mandatory_artifacts COMPLETED"],
        "evidence_check": ["ALL mandatory_evidence PRESENT"],
        "fusion_target_check": true,
        "veto_items": [
          "工件链不完整",
          "Gate 可被绕过",
          "无法基于黑板恢复",
          "demo 级结果伪装生产级",
          "Token 失控无法收敛",
          "无人值守空转或伪完成"
        ]
      },
      "budget": { "cost_usd": 3, "iterations": 5 }
    },

    {
      "id": "PHASE_10",
      "name": "部署上线",
      "description": "Docker 镜像 + CI/CD + 灰度发布 + 监控",
      "agents": ["@DevOps"],
      "parallel": false,
      "entry_conditions": ["PHASE_9.decision == GO"],
      "tasks": [
        {
          "id": "T10-1",
          "agent": "@DevOps",
          "action": "build_docker",
          "input": "代码 + 配置",
          "output": "Docker Image",
          "depends_on": []
        },
        {
          "id": "T10-2",
          "agent": "@DevOps",
          "action": "configure_cicd",
          "input": "Docker + 环境配置",
          "output": "CI/CD Pipeline",
          "depends_on": ["T10-1"]
        },
        {
          "id": "T10-3",
          "agent": "@DevOps",
          "action": "canary_deploy",
          "input": "CI/CD",
          "output": "10% → 50% → 100% 流量",
          "depends_on": ["T10-2"]
        },
        {
          "id": "T10-4",
          "agent": "@DevOps",
          "action": "configure_monitoring",
          "input": "服务指标",
          "output": "Grafana + Alert",
          "depends_on": ["T10-3"]
        },
        {
          "id": "T10-5",
          "agent": "@DevOps",
          "action": "24h_monitor",
          "input": "监控告警",
          "output": "稳定性确认",
          "depends_on": ["T10-4"]
        }
      ],
      "exit_gate": "production_24h_stable",
      "harness_discipline": {
        "mandatory_skills": ["verification-before-completion", "finishing-a-development-branch"],
        "enforcement": "发布前必须完成构建验证、隐私审计、安装测试、冒烟测试；缺少部署脚本/环境变量/回滚说明时不得宣告可直接部署",
        "artifact_check": ["Release-Notes.md"],
        "evidence_check": ["deploy_smoke_test", "build_verification"],
        "deploy_prerequisites": ["部署脚本", "环境变量说明", "回滚策略", "冒烟测试通过"]
      },
      "budget": { "cost_usd": 2, "iterations": 5 }
    }
  ],

  "quality_gates": {
    "gate1_code_review": {
      "skill": "gate1-code-review",
      "agent": "@Code-Reviewer",
      "trigger": "PHASE_5.completed",
      "pass_criteria": "blocker_count == 0 AND major_count == 0",
      "fail_action": "→ @Bug-Defect-Repairer → 回到 PHASE_5",
      "fusion_check": {
        "evidence_required": true,
        "fresh_verification": true,
        "no_soft_claims": true
      }
    },
    "gate2_performance": {
      "skill": "gate2-performance",
      "agent": "@Professional-Performance",
      "trigger": "GATE_1.passed",
      "pass_criteria": "all_sla_met == true",
      "fail_action": "→ @Bug-Defect-Repairer → 回到 PHASE_5",
      "fusion_check": {
        "evidence_required": true,
        "fresh_verification": true,
        "no_soft_claims": true
      }
    },
    "gate3_testing": {
      "skill": "gate3-testing",
      "agent": "@全栈测试员",
      "trigger": "GATE_2.passed",
      "pass_criteria": "p0 == 0 AND p1 == 0 AND p2 <= 3",
      "fail_action": "→ @Bug-Defect-Repairer → 回到 PHASE_5",
      "fusion_check": {
        "evidence_required": true,
        "fresh_verification": true,
        "no_soft_claims": true,
        "tdd_coverage_min": 80
      }
    },
    "gate4_final": {
      "skill": "gate4-final",
      "agent": "@Final-Reviewer",
      "trigger": "PHASE_8.completed",
      "pass_criteria": "risk_level == LOW OR MEDIUM (with approval)",
      "fail_action": "→ 回到对应 PHASE 修复",
      "fusion_check": {
        "all_artifacts_complete": true,
        "all_evidence_present": true,
        "deploy_prerequisites_met": true,
        "no_demo_disguised_as_production": true,
        "veto_check": true
      }
    }
  },

  "global_guardrails": {
    "max_budget_usd": 100.0,
    "max_total_iterations": 200,
    "max_iterations_per_task": 8,
    "no_progress_detection": true,
    "no_progress_threshold": 3,
    "loud_failure_only": true,
    "maker_checker_separation": true,
    "ralph_mode": true,
    "circuit_breaker": {
      "failure_threshold": 3,
      "reset_timeout_seconds": 60
    },
    "fusion_guardrails": {
      "no_gate_bypass": true,
      "no_evidenceless_completion": true,
      "no_demo_as_production": true,
      "no_deploy_without_prerequisites": true,
      "no_role_overreach": true,
      "no_repeat_failure_without_recovery": true,
      "veto_items": [
        "工件链不完整",
        "Gate 可被绕过",
        "无法基于黑板恢复",
